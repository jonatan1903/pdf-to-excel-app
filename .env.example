# Queue and Redis
REDIS_URL=redis://localhost:6379/0
QUEUE_NAME=pdf-jobs
JOB_TIMEOUT_SECONDS=7200
JOB_TTL_SECONDS=604800

# Storage backend: local (dev) or s3 (render/prod)
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=./storage

# S3/R2 (required when STORAGE_BACKEND=s3)
S3_BUCKET=
S3_REGION=
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
